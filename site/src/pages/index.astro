---
import { readFileSync } from 'fs';
import { join } from 'path';
import MarkdownIt from 'markdown-it';
import Base from '../layouts/Base.astro';

const essayPath = join(process.cwd(), '../content/essay.md');
const essayContent = readFileSync(essayPath, 'utf-8');

const md = new MarkdownIt({
  html: true,
  linkify: false,
  typographer: false
});

const htmlContent = md.render(essayContent);
---

<Base
  title="The Critical Engineer"
  description="An essay about software engineering when expression is cheap and judgment is not."
  canonical="https://criticalengineer.ai/"
>
  <Fragment set:html={htmlContent} />
  
  <nav style="margin-top: 2rem; padding-top: 2rem; border-top: 1px solid var(--color-border);">
    <a href="/principles">Read the principles →</a>
  </nav>
</Base>
