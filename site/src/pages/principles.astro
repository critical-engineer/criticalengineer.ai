---
import { readFileSync } from 'fs';
import { join } from 'path';
import MarkdownIt from 'markdown-it';
import Base from '../layouts/Base.astro';

const principlesPath = join(process.cwd(), '../content/principles.md');
const principlesContent = readFileSync(principlesPath, 'utf-8');

const md = new MarkdownIt({
  html: true,
  linkify: false,
  typographer: false
});

// Override link_open to add target="_blank" for external links
md.renderer.rules.link_open = function(tokens, idx) {
  const token = tokens[idx];
  const href = token.attrGet('href');
  
  // Add target="_blank" for external links
  if (href && (href.startsWith('http://') || href.startsWith('https://'))) {
    token.attrSet('target', '_blank');
    token.attrSet('rel', 'noopener noreferrer');
  }
  
  // Build the opening tag manually from token attributes
  let result = '<a';
  for (let i = 0; i < token.attrs.length; i++) {
    result += ` ${token.attrs[i][0]}="${token.attrs[i][1]}"`;
  }
  result += '>';
  return result;
};

const htmlContent = md.render(principlesContent);
---

<Base
  title="The Critical Engineer Principles"
  description="Working principles for engineering when expression is cheap and judgment is not."
  canonical="https://criticalengineer.ai/principles"
>
  <Fragment set:html={htmlContent} />
  
  <nav style="margin-top: 2rem; padding-top: 2rem; border-top: 1px solid var(--color-border);">
    <a href="/" style="text-decoration: none;">← Back to essay</a>
  </nav>
</Base>