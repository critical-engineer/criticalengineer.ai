---
import { readFileSync } from 'fs';
import { join } from 'path';
import MarkdownIt from 'markdown-it';
import Base from '../layouts/Base.astro';

const essayPath = join(process.cwd(), '../content/essay.md');
const essayContent = readFileSync(essayPath, 'utf-8');

const md = new MarkdownIt({
  html: true,
  linkify: false,
  typographer: false
});

// Custom link renderer for external links
const defaultRender = md.renderer.rules.link_open || function(tokens, idx) {
  return tokens[idx].attrGet('href') ? `<a href="${md.utils.escapeHtml(tokens[idx].attrGet('href'))}"` : '<a';
};

md.renderer.rules.link_open = function(tokens, idx) {
  const token = tokens[idx];
  const href = token.attrGet('href');
  
  // Check if link is external (starts with http/https)
  const isExternal = href && (href.startsWith('http://') || href.startsWith('https://'));
  
  if (isExternal) {
    token.attrSet('target', '_blank');
    token.attrSet('rel', 'noopener noreferrer');
  }
  
  return defaultRender(tokens, idx);
};

const htmlContent = md.render(essayContent);
---

<Base
  title="The Critical Engineer"
  description="An essay about software engineering when expression is cheap and judgment is not."
  canonical="https://criticalengineer.ai/"
>
  <Fragment set:html={htmlContent} />
  
  <nav style="margin-top: 2rem; padding-top: 2rem; border-top: 1px solid var(--color-border);">
    <a href="/principles" style="text-decoration: none;">Read the principles →</a>
  </nav>
</Base>